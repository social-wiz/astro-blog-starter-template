<section class="fr-livery fr-reveal">
	<div class="fr-livery-inner">
		<h2>The Only Media Agency That Guarantees Results</h2>
		<p class="fr-livery-promise">
			If we miss it, we refund 50% of that month's retainer. In writing.
		</p>
		<div class="fr-livery-points">
			<p>Month-to-month contracts. No lock-in.</p>
			<p>Your team owns the work — no juniors, no handoffs.</p>
		</div>
		<a class="fr-btn fr-btn-outline fr-livery-cta" href="#cta">How the Guarantee Works</a>
	</div>
</section>

<style>
	.fr-livery {
		background: var(--fr-primary);
		padding: var(--fr-xxl) var(--fr-xs);
	}
	.fr-livery-inner {
		max-width: 1280px;
		margin: 0 auto;
	}
	h2 {
		font-size: 36px;
		font-weight: 500;
		line-height: 1.2;
		letter-spacing: -0.36px;
		color: var(--fr-on-primary);
		max-width: 20ch;
	}
	.fr-livery-promise {
		font-size: 18px;
		font-weight: 700;
		line-height: 1.4;
		color: var(--fr-on-primary);
		margin: var(--fr-sm) 0 0;
	}
	.fr-livery-points {
		display: flex;
		gap: var(--fr-lg);
		flex-wrap: wrap;
		margin-top: var(--fr-md);
	}
	.fr-livery-points p {
		font-size: 14px;
		color: rgba(255, 255, 255, 0.85);
		margin: 0;
	}
	.fr-livery-cta {
		margin-top: var(--fr-lg);
		border-color: var(--fr-on-primary);
	}
	.fr-livery-cta:hover {
		background: var(--fr-on-primary);
		color: var(--fr-primary);
	}
</style>
