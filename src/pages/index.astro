---
import BaseHead from '../components/BaseHead.astro';
import FerrariNav from '../components/landing/FerrariNav.astro';
import Hero from '../components/landing/Hero.astro';
import Guarantee from '../components/landing/Guarantee.astro';
import ClientLogos from '../components/landing/ClientLogos.astro';
import Solutions from '../components/landing/Solutions.astro';
import CaseStudies from '../components/landing/CaseStudies.astro';
import Testimonials from '../components/landing/Testimonials.astro';
import Awards from '../components/landing/Awards.astro';
import CtaBand from '../components/landing/CtaBand.astro';
import FerrariFooter from '../components/landing/FerrariFooter.astro';

const title = "KPI Media — Singapore's Fastest Growing Media Agency";
const description =
	'Your KPIs are our KPIs. The only performance media agency that guarantees results — in writing.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="ferrari">
		<FerrariNav />
		<main>
			<Hero />
			<Guarantee />
			<ClientLogos />
			<Solutions />
			<CaseStudies />
			<Testimonials />
			<Awards />
			<CtaBand />
		</main>
		<FerrariFooter />
		<script>
			const revealEls = document.querySelectorAll('.fr-reveal');
			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							entry.target.classList.add('fr-visible');
							observer.unobserve(entry.target);
						}
					}
				},
				{ threshold: 0.15 },
			);
			revealEls.forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
